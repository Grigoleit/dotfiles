{
  "cheatsheetData": [
    {
      "title": "CHEATSHEET",
      "binds": [
        {
          "keys": "Super + F1",
          "desc": "Toggle this window."
        }
      ]
    },
    {
      "title": "GENERAL",
      "binds": [
        {
          "keys": "Alt + SPACE",
          "desc": "Launcher"
        },
        {
          "keys": "Alt + DEAD_GRAVE",
          "desc": "Opens Terminal (Kitty)"
        },
        {
          "keys": "Super + C",
          "desc": "Kills active window"
        },
        {
          "keys": "Super + E",
          "desc": "Opens filemanager (Dolphin)"
        },
        {
          "keys": "Super + V",
          "desc": "Toogle floating window"
        },
        {
          "keys": "Super + J",
          "desc": "Toggle split-layout"
        },
        {
          "keys": "Super + K",
          "desc": "Swaps the two halves of the split of the current window"
        },
        {
          "keys": "Super + R",
          "desc": "Rotates split-layout"
        }
      ]
    },
    {
      "title": "MOVE FOCUS",
      "binds": [
        {
          "keys": "Super + LEFT",
          "desc": "Move left"
        },
        {
          "keys": "Super + RIGHT",
          "desc": "Move right"
        },
        {
          "keys": "Super + UP",
          "desc": "Move up"
        },
        {
          "keys": "Super + DOWN",
          "desc": "Move down"
        }
      ]
    },
    {
      "title": "SWITCH WORKSPACES",
      "binds": [
        {
          "keys": "Super + 1",
          "desc": "Workspace 1"
        },
        {
          "keys": "Super + 2",
          "desc": "Workspace 2"
        },
        {
          "keys": "Super + 3",
          "desc": "Workspace 3"
        },
        {
          "keys": "Super + 4",
          "desc": "Workspace 4"
        },
        {
          "keys": "Super + 5",
          "desc": "Workspace 5"
        },
        {
          "keys": "Super + 6",
          "desc": "Workspace 6"
        },
        {
          "keys": "Super + 7",
          "desc": "Workspace 7"
        },
        {
          "keys": "Super + 8",
          "desc": "Workspace 8"
        },
        {
          "keys": "Super + 9",
          "desc": "Workspace 9"
        },
        {
          "keys": "Super + 0",
          "desc": "Workspace 10"
        }
      ]
    },
    {
      "title": "MOVE WINDOW TO WORKSPACES",
      "binds": [
        {
          "keys": "Super + Shift + 1",
          "desc": "Move to workspace 1"
        },
        {
          "keys": "Super + Shift + 2",
          "desc": "Move to workspace 2"
        },
        {
          "keys": "Super + Shift + 3",
          "desc": "Move to workspace 3"
        },
        {
          "keys": "Super + Shift + 4",
          "desc": "Move to workspace 4"
        },
        {
          "keys": "Super + Shift + 5",
          "desc": "Move to workspace 5"
        },
        {
          "keys": "Super + Shift + 6",
          "desc": "Move to workspace 6"
        },
        {
          "keys": "Super + Shift + 7",
          "desc": "Move to workspace 7"
        },
        {
          "keys": "Super + Shift + 8",
          "desc": "Move to workspace 8"
        },
        {
          "keys": "Super + Shift + 9",
          "desc": "Move to workspace 9"
        },
        {
          "keys": "Super + Shift + 0",
          "desc": "Move to workspace 10"
        }
      ]
    },
    {
      "title": "MOVE WORKSPACE TO MONITOR",
      "binds": [
        {
          "keys": "Super + Shift + LEFT",
          "desc": "Move left"
        },
        {
          "keys": "Super + Shift + RIGHT",
          "desc": "Move right"
        }
      ]
    },
    {
      "title": "FULLSCREEN",
      "binds": [
        {
          "keys": "Super + Ctrl + F",
          "desc": "Normal fullscreen, e.g. for games"
        },
        {
          "keys": "Super + F",
          "desc": "Maximize windows"
        },
        {
          "keys": "Super + Shift + F",
          "desc": "Fullscreen inside a tile"
        }
      ]
    },
    {
      "title": "SCRATCHPAD",
      "binds": [
        {
          "keys": "Super + S",
          "desc": "Toggle scratchpad"
        },
        {
          "keys": "Super + Shift + S",
          "desc": "Move active window to scratchpad"
        }
      ]
    },
    {
      "title": "MOUSE SETTINGS",
      "binds": [
        {
          "keys": "Super + Left Click",
          "desc": "Move window"
        },
        {
          "keys": "Super + Right Click",
          "desc": "Resize window"
        },
        {
          "keys": "Super + Scroll Down",
          "desc": "Next workspace"
        },
        {
          "keys": "Super + Scroll Up",
          "desc": "Previous workspace"
        }
      ]
    },
    {
      "title": "SCREENSHOT",
      "binds": [
        {
          "keys": "Shift + Ctrl + 4",
          "desc": "Region Capture"
        },
        {
          "keys": "PrtSc",
          "desc": "Region Capture"
        }
      ]
    }
  ],
  "detectedCompositor": "hyprland",
  "windowWidth": 1400,
  "windowHeight": 850,
  "autoHeight": true,
  "columnCount": 3,
  "modKeyVariable": "$mainMod",
  "hyprlandConfigPath": "~/.config/hypr/hyprland/keybinds.conf",
  "niriConfigPath": "~/.config/niri/config.kdl"
}
